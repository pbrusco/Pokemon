#!/usr/bin/env bash
# Pre-commit gate. Runs the same checks as CI.
# Enable once per clone: `git config core.hooksPath .githooks`
# (npm install wires this automatically via the "prepare" script.)

set -e

export PATH="/opt/homebrew/bin:$PATH"

echo "[pre-commit] tsc --noEmit"
npx tsc --noEmit

echo "[pre-commit] tsc --noUnusedLocals --noUnusedParameters (filtered)"
OUTPUT=$(npx tsc --noEmit --noUnusedLocals --noUnusedParameters 2>&1 || true)
FILTERED=$(echo "$OUTPUT" | grep -E "error TS(6133|6192|6196|6198)" | grep -v node_modules || true)
if [ -n "$FILTERED" ]; then
  echo "Unused imports/locals/params detected:"
  echo "$FILTERED"
  exit 1
fi

echo "[pre-commit] vitest run"
npm run test:run --silent

echo "[pre-commit] knip"
npx knip --no-progress
